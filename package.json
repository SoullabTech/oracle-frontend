{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:swisseph": "cd swisseph && emcc sweph.c swephlib.c swedate.c swehouse.c swehel.c swecl.c swejpl.c swemini.c swephgen4.c swevents.c swemplan.c \\\n  -O3 \\\n  -s MODULARIZE=1 \\\n  -s EXPORT_NAME=\"createSwissephModule\" \\\n  -s ALLOW_MEMORY_GROWTH=1 \\\n  -s EXPORTED_FUNCTIONS='[\"_JulianDay\",\"_calc_ut\"]' \\\n  -s EXTRA_EXPORTED_RUNTIME_METHODS='[\"cwrap\"]' \\\n  --no-entry \\\n  -Wl,--allow-multiple-definition \\\n  -o ../public/swisseph.js",
    "dev": "vite",
    "build": "vite build --config vite.config.prod.ts",
    "preview": "vite preview --port 8080",
    "boot": "concurrently \"npm run start\" \"npm run dev\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "start": "node server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:a11y": "vitest --include \"**/*.a11y.test.tsx\""
  },
  "dependencies": {
    "@supabase/auth-helpers-react": "^0.5.0",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/supabase-js": "^2.49.4",
    "axios": "^1.9.0",
    "body-parser": "^2.2.0",
    "dotenv": "^16.5.0",
    "event-source-polyfill": "^1.0.31",
    "express": "^5.1.0",
    "framer-motion": "^12.12.1",
    "openai": "^4.100.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.6.0",
    "react-tsparticles": "^2.12.2",
    "tsparticles": "^3.8.1",
    "zustand": "^5.0.3",
    "react-datepicker": "^4.16.0",
    "recharts": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.7",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "3.1.3",
    "@vitest/ui": "3.1.3",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.6",
    "vite": "^6.3.5",
    "vitest": "^3.1.1"
  },
  "description": "🌸 Spiralogic Oracle Portal 🌀 A Sacred Spiral Temple for Dreamers, Leaders, Healers, and Awakening Souls.",
  "main": "eslint.config.js",
  "directories": {
    "doc": "docs",
    "lib": "lib"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
