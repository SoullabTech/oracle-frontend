{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "baseUrl": ".",

    // ✅ Absolute imports from apps & packages
    "paths": {
      "@/*": ["src/*"],                           // Local app-level imports
      "@frontend/*": ["apps/frontend/src/*"],     // Frontend monorepo apps
      "@backend/*": ["apps/backend/src/*"],       // Backend monorepo apps
      "@agents": ["packages/agents/src"],         // Shared agents
      "@components/*": ["src/components/*"],      // Optional: frontend alias
      "@lib/*": ["src/lib/*"],
      "@test-utils/*": ["src/test-utils/*"]
    },

    // ✅ Vite & Vitest compatibility
    "types": ["vite/client", "vitest/globals"],

    "noEmit": true
  },
  "exclude": ["node_modules", "dist", "coverage"]
}
