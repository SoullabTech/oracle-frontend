{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "baseUrl": "./",
    "allowJs": false,
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": true,
    "paths": {
      "@/*": ["src/*"],
      "@services/*": ["src/services/*"],
      "@utils/*": ["src/utils/*"],
      "@lib/*": ["src/lib/*"]
    },
    "types": ["vite/client", "vitest/globals"]
  },
  "include": ["src", "src/types", "test", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
