{
  "builds": [
    {
      "src": "vite.config.prod.ts",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/" }
  ],
  "ignore": [
    "node_modules",
    ".vscode",
    ".git",
    ".gitignore",
    "README.md",
    "readme.md",
    "tests",
    "test",
    "coverage",
    "*.log",
    "*.tsbuildinfo",
    "public/sounds/",
    "src/components/_tests_/",
    "src/tests/",
    "supabase/functions/",
    ".env",
    ".env.local"
  ]
}
